{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/SnowGlow-aww/sekaitext-plugins/main/index.schema.json",
  "title": "SekaiText plugin market index",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "plugins"],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [2, 3]
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "$ref": "#/$defs/plugin"
      }
    },
    "publisher": { "const": "sekaitext-official" },
    "keyId": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" },
    "signatureAlgorithm": { "const": "ed25519" },
    "sequence": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "expiresAt": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "snapshotSignature": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "version": { "const": 3 }
        },
        "required": ["version"]
      },
      "then": {
        "required": ["publisher", "keyId", "signatureAlgorithm", "sequence", "expiresAt", "snapshotSignature"],
        "properties": {
          "plugins": {
            "items": {
              "required": ["publisher", "keyId", "signatureAlgorithm", "packageSignature", "sequence", "expiresAt", "metadataSignature"]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "version": { "const": 2 }
        },
        "required": ["version"]
      },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["publisher"] },
            { "required": ["keyId"] },
            { "required": ["signatureAlgorithm"] },
            { "required": ["sequence"] },
            { "required": ["expiresAt"] },
            { "required": ["snapshotSignature"] }
          ]
        },
        "properties": {
          "plugins": {
            "items": {
              "not": {
                "anyOf": [
                  { "required": ["sequence"] },
                  { "required": ["expiresAt"] },
                  { "required": ["metadataSignature"] }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "download", "sha256", "publisher", "keyId", "signatureAlgorithm", "packageSignature"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,64}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
        "description": { "type": "string", "maxLength": 4000 },
        "author": { "type": "string", "maxLength": 200 },
        "icon": { "type": "string", "maxLength": 100 },
        "minHostVersion": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
        "download": { "type": "string", "format": "uri", "pattern": "^https://" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "publisher": { "const": "sekaitext-official" },
        "keyId": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" },
        "signatureAlgorithm": { "const": "ed25519" },
        "packageSignature": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" },
        "homepage": { "type": "string", "format": "uri", "pattern": "^https://" },
        "sequence": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "expiresAt": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
        "metadataSignature": { "type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$" }
      }
    }
  }
}
